# === 必须修改（首次部署）===
JSA_ENV=prod

# 生成方式：python -c "import secrets; print(secrets.token_urlsafe(48))"
JSA_SECRET_KEY=CHANGE_ME_to_a_long_random_string_at_least_32_chars

# 生成方式：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
JSA_MASTER_KEY=CHANGE_ME_base64_fernet_key

# === 数据库 ===
# Docker 模式用容器服务名：db / redis
# 物理机模式用 localhost
JSA_DB_URL=postgresql+psycopg2://jsa:jsa_pass_2026@localhost:5432/jimeng_saas
JSA_REDIS_URL=redis://localhost:6379/0

# === 上游服务 ===
# 即梦 API（Node.js，端口 5100）
JSA_JIMENG_UPSTREAM=http://localhost:5100

# Monica Proxy（Go，端口 8080）
# 必须和 monica-proxy config.yaml 的 bearer_token 一致
JSA_MONICA_PROXY_BASE_URL=http://127.0.0.1:8080
JSA_MONICA_PROXY_TOKEN=mytoken123

# OpenAI 兼容图片生成（可选）
JSA_OPENAI_IMAGE_BASE_URL=
JSA_OPENAI_IMAGE_API_KEY=

# === 管理员 ===
JSA_ADMIN_EMAIL=admin@example.com
JSA_ADMIN_PASSWORD=admin123

# === 其他 ===
JSA_BASE_URL=http://localhost:8000
JSA_STORAGE_BACKEND=local
JSA_STORAGE_LOCAL_DIR=data/artifacts
